{
  "name": "oclock",
  "version": "0.0.0",
  "scripts": {
    "config": "node scripts/set-env.js",
    "config:prod": "node scripts/set-env.js --prod",
    "ng": "ng",
    "start": "bun run config && ng serve",
    "build": "bun run config && ng build --configuration development",
    "build:prod": "bun run config:prod && ng build --configuration production",
    "watch": "bun run config && ng build --watch --configuration development",
    "test": "bun run config && ng test",
    "test:run": "bun run config && ng test --watch=false",
    "lint": "ng lint"
  },
  "private": true,
  "packageManager": "bun@1.3.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "dotenv": "^17.4.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.3.1",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.12",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
